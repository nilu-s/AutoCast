{
    "name":  "autocast",
    "version":  "2.2.0",
    "description":  "AutoCast - Automatic podcast multi-track cut editing plugin for Adobe Premiere Pro",
    "main":  "apps/panel/index.html",
    "scripts":  {
                    "test":  "node packages/analyzer/test/run_all_tests.js",
                    "test:unit":  "node packages/analyzer/test/test_runner.js unit",
                    "test:integration":  "node packages/analyzer/test/test_runner.js integration",
                    "test:e2e":  "node packages/analyzer/test/test_runner.js e2e",
                    "check:syntax":  "node scripts/check_syntax.js",
                    "check:structure":  "node scripts/check_structure.js",
                    "check":  "npm run check:syntax && npm run check:structure && npm test",
                    "test:wav":  "node packages/analyzer/test/test_wav_reader.js",
                    "test:rms":  "node packages/analyzer/test/test_rms.js",
                    "test:segments":  "node packages/analyzer/test/test_segmentation.js",
                    "test:overlap":  "node packages/analyzer/test/test_overlap.js",
                    "generate-test-data":  "node packages/analyzer/test/generate_test_wav.js",
                    "analyze":  "node packages/analyzer/src/analyzer.js"
                },
    "keywords":  [
                     "premiere",
                     "podcast",
                     "audio",
                     "speech-editing",
                     "cep"
                 ],
    "author":  "",
    "license":  "MIT"
}

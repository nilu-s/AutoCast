<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   Version="11.0"
                   ExtensionBundleId="com.autocast.panel"
                   ExtensionBundleVersion="2.2.0"
                   ExtensionBundleName="AutoCast">

    <ExtensionList>
        <Extension Id="com.autocast.panel.main" Version="2.2.0" />
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <!-- Premiere Pro CC 2021+ (Version 15.0+) -->
            <Host Name="PPRO" Version="[15.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="11.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.autocast.panel.main">
            <DispatchInfo>
                <Resources>
                    <MainPath>./apps/panel/index.html</MainPath>
                    <ScriptPath>./apps/panel/jsx/host.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>AutoCast</Menu>
                    <Geometry>
                        <Size>
                            <Height>650</Height>
                            <Width>380</Width>
                        </Size>
                        <MinSize>
                            <Height>400</Height>
                            <Width>320</Width>
                        </MinSize>
                        <MaxSize>
                            <Height>1200</Height>
                            <Width>600</Width>
                        </MaxSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
